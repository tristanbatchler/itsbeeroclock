{
  "enabled": true,
  "name": "Run Tests After Task",
  "description": "Runs vitest after each completed agent task to catch regressions",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "cd frontend && npx vitest run",
    "timeout": 60
  }
}